{
  "name": "skillpro",
  "version": "2.7.3",
  "description": "Zero-config federated skill discovery for AI coding agents",
  "type": "module",
  "bin": {
    "skillpro": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/config"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf dist/config && cp -r src/config dist/config",
    "build:registry": "tsx scripts/build-registry.ts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "skills",
    "claude",
    "cursor",
    "codex",
    "ai",
    "discovery",
    "federated",
    "zero-config"
  ],
  "author": "Yasin Coskun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yajinn/skillpro"
  },
  "homepage": "https://yajinn.github.io/SkillPro/",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "tsx": "^4.0.0",
    "@types/node": "^22.0.0"
  }
}
